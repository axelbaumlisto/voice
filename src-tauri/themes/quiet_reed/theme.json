{
  "name": "Quiet Reed",
  "description": "Minimal motion, cool blue palette — ambient always-on indicator.",
  "family": "organic_ring",
  "colors": {
    "background": "#00000000",
    "idle": "#3d5168",
    "recording": "#7a9fbd",
    "recording_peak": "#b8d0e6",
    "transcribing": "#4caf50",
    "queued": "#ffa726",
    "text": "#ffffff"
  },
  "use_gradient": true,
  "gradient": {
    "bottom": "#3d5168",
    "middle": "#7a9fbd",
    "top": "#b8d0e6"
  },
  "organic_ring": {
    "shape": {
      "gap_degrees": 60.0,
      "base_thickness": 5.0,
      "taper": 0.4,
      "roundness": 0.95,
      "active_zones": 2
    },
    "motion": {
      "idle_breathing": 0.05,
      "speech_responsiveness": 0.6,
      "drift": 0.15,
      "settle_speed": 0.8
    }
  },
  "handy_pill": {
    "palette": {
      "icon_color": "#7a9fbd",
      "bar_color": "#b8d0e6",
      "bar_glow": "#7a9fbd",
      "shadow": "rgba(0, 0, 0, 0.45)",
      "transcribing_text": "#ffffff",
      "cancel_hover_bg": "rgba(255, 255, 255, 0.15)"
    },
    "animation": {
      "smoothing_alpha": 0.41,
      "bar_height_ms": 56,
      "idle_breathing_amplitude": 0.05,
      "idle_breathing_period_ms": 4000,
      "peak_decay": 0.95
    }
  }
}
